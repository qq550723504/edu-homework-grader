# DEVELOPMENT ONLY. Copy this file only for local integration tests.
# Production values must be injected from the deployment secret manager; never
# deploy this file or any value below to a shared environment.
APP_ENV=development
API_PORT=8000
GRADER_PORT=8010
WEB_PORT=3000
POSTGRES_DB=edu_grader
POSTGRES_USER=edu_grader
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://edu_grader:change-me@postgres:5432/edu_grader
REDIS_URL=redis://redis:6379/0
GRADER_BASE_URL=http://grader:8010
LANGUAGETOOL_BASE_URL=http://languagetool:8010/v2
LANGUAGETOOL_TIMEOUT_SECONDS=2
ENGLISH_EMBEDDING_MODEL_DIRECTORY=/opt/english-model
ENGLISH_EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
ENGLISH_EMBEDDING_MODEL_REVISION=1110a243fdf4706b3f48f1d95db1a4f5529b4d41
ENGLISH_EMBEDDING_MODEL_DIGEST=sha256:84714cdabb16d132cbe6e1a4cbd21167abd09eccbdaf69dd053136ae68cc7c17
AUDIT_HMAC_KEY=development-only-change-me-32-bytes-minimum
AUDIT_HMAC_KEY_VERSION=dev-1
PROCESSOR_ALLOWED_HOSTS=grader,languagetool,localhost
# Default local provider is deterministic and does not make network calls.
# Use an injected secret manager value in production; never commit an API key.
GENERATION_PROVIDER=fake
OPENAI_API_KEY=
# When GENERATION_PROVIDER=openai, use an explicitly approved fixed model snapshot.
GENERATOR_OPENAI_MODEL=
GENERATOR_OPENAI_BASE_URL=https://api.openai.com
GENERATOR_PROVIDER_ALLOWED_HOSTS=api.openai.com
GENERATOR_TIMEOUT_SECONDS=30
GENERATOR_DAILY_TENANT_LIMIT=100
GENERATOR_MAX_BATCH_SIZE=20
NUXT_PUBLIC_API_BASE=http://localhost:8000
OIDC_ISSUER=http://keycloak:8080/realms/edu-grader
OIDC_AUDIENCE=edu-grader-api
OIDC_SCHOOL_ID_CLAIM=school_id
OIDC_TENANT_SLUG=pilot
BOOTSTRAP_ADMIN_SUB=00000000-0000-0000-0000-000000000001
BOOTSTRAP_ADMIN_TENANT_SLUG=pilot
CURRICULUM_ADMIN_SUBJECTS=00000000-0000-0000-0000-000000000001
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=change-me
