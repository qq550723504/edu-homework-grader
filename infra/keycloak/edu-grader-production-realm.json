{
  "realm": "edu-grader",
  "enabled": true,
  "displayName": "Edu Homework Grader",
  "roles": {
    "realm": [
      {"name": "admin"},
      {"name": "teacher"},
      {"name": "student"},
      {"name": "offline_access"}
    ]
  },
  "clients": [
    {
      "clientId": "edu-grader-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "edu-grader-web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["https://edu.getkr.com/*"],
      "webOrigins": ["https://edu.getkr.com"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "offline_access",
        "edu-grader-api-audience",
        "edu-grader-subject",
        "school-id"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "edu-grader-api-audience",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "edu-grader-api audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "edu-grader-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "school-id",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "school_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "school_id",
            "claim.name": "school_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "edu-grader-subject",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "subject",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ]
}
