{
  "realm": "edu-grader",
  "enabled": true,
  "displayName": "Edu Homework Grader (development)",
  "roles": {
    "realm": [
      {"name": "admin"},
      {"name": "teacher"},
      {"name": "student"}
    ]
  },
  "clients": [
    {
      "clientId": "edu-grader-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "edu-grader-web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "basic",
        "email",
        "edu-grader-api-audience",
        "school-id"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "edu-grader-api-audience",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "edu-grader-api audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "edu-grader-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "school-id",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "school_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "school_id",
            "claim.name": "school_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "id": "00000000-0000-0000-0000-000000000001",
      "username": "pilot-admin",
      "enabled": true,
      "attributes": {"school_id": ["ADMIN-001"]},
      "realmRoles": ["admin"],
      "credentials": [{"type": "password", "value": "admin-change-me", "temporary": false}]
    }
  ]
}
