{
  "realm": "edu-grader",
  "enabled": true,
  "displayName": "Edu Homework Grader (development)",
  "roles": {
    "realm": [
      {"name": "admin"},
      {"name": "teacher"},
      {"name": "student"},
      {"name": "offline_access"}
    ]
  },
  "clients": [
    {
      "clientId": "edu-grader-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "edu-grader-web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:13000/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:13000"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
        "defaultClientScopes": [
          "offline_access",
          "edu-grader-api-audience",
          "edu-grader-subject",
          "school-id"
        ]
    }
  ],
  "clientScopes": [
    {
      "name": "edu-grader-api-audience",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "edu-grader-api audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "edu-grader-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
      {
        "name": "school-id",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "school_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "school_id",
            "claim.name": "school_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
        ]
      },
      {
        "name": "edu-grader-subject",
        "protocol": "openid-connect",
        "protocolMappers": [
          {
            "name": "subject",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-sub-mapper",
            "consentRequired": false,
            "config": {
              "access.token.claim": "true",
              "id.token.claim": "true",
              "userinfo.token.claim": "true",
              "introspection.token.claim": "true"
            }
          }
        ]
      }
  ],
  "users": [
    {
      "id": "00000000-0000-0000-0000-000000000001",
      "username": "pilot-admin",
      "enabled": true,
      "firstName": "Pilot",
      "lastName": "Admin",
      "email": "pilot-admin@example.invalid",
      "emailVerified": true,
      "attributes": {"school_id": ["ADMIN-001"]},
      "realmRoles": ["admin", "offline_access"],
      "credentials": [{"type": "password", "value": "admin-change-me", "temporary": false}]
    },
    {
      "id": "00000000-0000-0000-0000-000000000002",
      "username": "pilot-teacher",
      "enabled": true,
      "firstName": "Pilot",
      "lastName": "Teacher",
      "email": "pilot-teacher@example.invalid",
      "emailVerified": true,
      "attributes": {"school_id": ["TEACHER-001"]},
      "realmRoles": ["teacher", "offline_access"],
      "credentials": [{"type": "password", "value": "teacher-change-me", "temporary": false}]
    },
    {
      "id": "00000000-0000-0000-0000-000000000003",
      "username": "pilot-student",
      "enabled": true,
      "firstName": "Pilot",
      "lastName": "Student",
      "email": "pilot-student@example.invalid",
      "emailVerified": true,
      "attributes": {"school_id": ["STUDENT-001"]},
      "realmRoles": ["student", "offline_access"],
      "credentials": [{"type": "password", "value": "student-change-me", "temporary": false}]
    }
  ]
}
